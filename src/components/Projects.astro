---
import type { ImageMetadata } from "astro";
import Section from "../shared/components/Section.astro";

export interface ProjectItem {
  projectName: string;
  projectDescription: string;
  projectTechnologies: string[];
  projectDuration: string;
  projectImage?: string | ImageMetadata;
  githubUrl?: string;
  githubText?: string;
  websiteUrl?: string;
  websiteText?: string;
}

export interface Props {
  projects?: ProjectItem[];
}

const { projects = [] } = Astro.props as Props;
---

<Section
  id="projects"
  border="border-y border-white/5"
  padding="py-16 md:py-24 lg:py-32"
  background="bg-[#0a0a0a]"
>
  <div class="w-full">
    <div
      class="mb-10 lg:mb-20 flex flex-col md:flex-row md:justify-between md:items-end gap-6 border-b border-white/10 pb-8 rounded-sm"
    >
      <div>
        <h2
          class="font-headline text-xs sm:text-sm tracking-[0.3em] md:tracking-[0.4em] text-maroon-deep uppercase mb-4 font-bold"
        >
          ¿Puedo trabajar solo?
        </h2>
        <h3
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-bold"
        >
          <span class="text-white">¡Claro</span>
          <span class="text-maroon-deep">que si!</span>
        </h3>
      </div>
      <div
        class="text-on-surface-variant font-label text-sm uppercase tracking-widest opacity-40 md:border-l border-white/10 md:pl-6"
      >
        03 / Proyectos personales
      </div>
    </div>

    <div class="flex flex-col gap-12 lg:gap-16">
      {
        projects.map((project, index) => (
          <div class="grid grid-cols-1 lg:grid-cols-2 bg-[#141414] rounded-xl overflow-hidden border border-white/5">
            {/* Image section */}
            <div
              class={`relative aspect-4/3 lg:aspect-auto flex items-center justify-center p-8 bg-[#1a1a1a] ${index % 2 !== 0 ? "lg:order-2" : ""}`}
            >
              <div
                class={`absolute top-6 md:top-8 z-10 ${index % 2 !== 0 ? "right-6 md:right-8" : "left-6 md:left-8"}`}
              >
                <span class="px-3 py-1.5 md:px-4 md:py-2 text-[10px] md:text-xs font-label tracking-[0.2em] uppercase border border-white/10 rounded-full bg-black/60 text-white/80 backdrop-blur-sm">
                  {project.projectDuration}
                </span>
              </div>

              {project.projectImage ? (
                <img
                  src={
                    typeof project.projectImage === "string"
                      ? project.projectImage
                      : project.projectImage.src
                  }
                  alt={project.projectName}
                  class="w-full h-full object-cover rounded-lg opacity-80 hover:opacity-100 transition-opacity duration-500"
                />
              ) : (
                <div class="w-32 h-32 opacity-10 flex items-center justify-center">
                  <svg
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    class="w-full h-full"
                  >
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z" />
                  </svg>
                </div>
              )}
            </div>

            {/* Content section */}
            <div
              class={`p-6 sm:p-8 md:p-12 lg:p-16 flex flex-col justify-center ${index % 2 !== 0 ? "lg:order-1" : ""}`}
            >
              <span class="text-maroon-deep text-lg font-bold mb-6 font-label">
                0{index + 1}.
              </span>

              <h4 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-headline font-bold text-white mb-4 lg:mb-6 leading-tight">
                {project.projectName}
              </h4>

              <p class="text-white/60 font-label leading-relaxed mb-10 text-base md:text-lg">
                {project.projectDescription}
              </p>

              <div class="flex flex-wrap gap-3 mb-12">
                {project.projectTechnologies.map((tech) => (
                  <span class="px-3 py-1.5 md:px-4 md:py-2 border border-white/10 rounded font-label text-[10px] md:text-xs tracking-[0.2em] text-white/60 uppercase">
                    {tech}
                  </span>
                ))}
              </div>

              <div class="mt-auto flex flex-wrap gap-4 sm:gap-8 items-center pt-6 border-t border-white/5">
                {project.githubUrl && (
                  <a
                    href={project.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-3 text-xs md:text-sm font-headline tracking-[0.2em] text-white hover:text-maroon-deep transition-colors uppercase font-bold group"
                  >
                    {project.githubText || "Visitar GitHub"}
                    <svg
                      class="w-4 h-4 text-maroon-deep group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        stroke-linecap="square"
                        stroke-linejoin="miter"
                        stroke-width="2"
                        d="M5 19L19 5M19 5v10M19 5H9"
                      />
                    </svg>
                  </a>
                )}

                {project.websiteUrl && (
                  <a
                    href={project.websiteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-3 text-xs md:text-sm font-headline tracking-[0.2em] text-white hover:text-maroon-deep transition-colors uppercase font-bold group"
                  >
                    {project.websiteText || "Visitar Página"}
                    <svg
                      class="w-4 h-4 text-maroon-deep group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        stroke-linecap="square"
                        stroke-linejoin="miter"
                        stroke-width="2"
                        d="M5 19L19 5M19 5v10M19 5H9"
                      />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
