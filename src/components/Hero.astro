---
import Section from "../shared/components/Section.astro";

export interface Props {
  firstNames: string;
  lastNames: string;
  topText: string;
  description: string;
  technologies: string[];
  yearsOfExperience: number;
}

const {
  firstNames,
  lastNames,
  topText,
  description,
  technologies,
  yearsOfExperience,
} = Astro.props as Props;
---

<Section
  id="hero"
  border="border-y border-white/5"
  background="bg-transparent"
  padding="pt-32 pb-20 md:py-20"
>
  <div
    class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-12 items-center min-h-screen"
  >
    <div class="order-2 md:order-1 flex flex-col justify-center">
      <span
        class="text-[#b27d7c] uppercase tracking-[0.3em] text-[10px] sm:text-xs font-semibold mb-6 block"
        >{topText}</span
      >
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-[6.5rem] font-bold leading-[0.85] tracking-tighter mb-8 text-white wrap-break-word"
      >
        {firstNames}<br /><span class="text-[#98141d]">{lastNames}</span>
      </h1>
      <p
        class="text-gray-400 text-base md:text-lg lg:text-xl max-w-lg mb-10 leading-relaxed font-light"
      >
        {description}
      </p>

      <div class="flex flex-wrap gap-3">
        {
          technologies.map((tech) => (
            <span class="px-3 py-1.5 bg-[#252629] text-gray-400 text-[9px] sm:text-[10px] uppercase tracking-widest rounded-sm font-semibold">
              {tech}
            </span>
          ))
        }
      </div>
    </div>

    <div class="order-1 md:order-2 relative group w-full flex justify-end">
      <div
        class="w-full max-w-[500px] aspect-square bg-[#151518] overflow-hidden relative flex items-center justify-center bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-size-[32px_32px]"
      >
        <div class="absolute inset-0 border border-white/5"></div>

        <div
          class="z-10 flex flex-col items-center gap-6 w-full overflow-hidden"
        >
          <div class="z-10 w-full overflow-hidden">
            <div class="carousel flex gap-8 whitespace-nowrap">
              {
                [...technologies, ...technologies].map((tech) => (
                  <span class="text-white/70 text-sm tracking-widest uppercase font-semibold">
                    {tech}
                  </span>
                ))
              }
            </div>
          </div>

          <div class="z-10 w-full overflow-hidden">
            <div class="carousel-reverse flex gap-8 whitespace-nowrap">
              {
                [
                  ...[...technologies].reverse(),
                  ...[...technologies].reverse(),
                ].map((tech) => (
                  <span class="text-white/70 text-sm tracking-widest uppercase font-semibold">
                    {tech}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div
        class="absolute bottom-0 left-0 md:-bottom-6 md:-left-6 lg:-bottom-8 lg:-left-8 bg-[#98141d] p-4 sm:p-6 lg:p-10 flex flex-col justify-center items-start shadow-xl md:shadow-none translate-y-4 -translate-x-4 md:translate-y-0 md:translate-x-0"
      >
        <span
          class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-1 sm:mb-2 leading-none"
          >{yearsOfExperience}</span
        >
        <span
          class="text-[7px] sm:text-[8px] lg:text-[9px] uppercase tracking-widest text-white/80 font-bold"
          >Año de experiencia</span
        >
      </div>
    </div>
  </div>
</Section>
