---
import type { ImageMetadata } from "astro";
import Section from "../shared/components/Section.astro";

interface CommentItem {
  comment: string;
  fullName: string;
  specialty: string;
  photoUrl: string | ImageMetadata;
  linkedInUrl: string;
}

const { comments } = Astro.props as { comments: CommentItem[] };

const getInitials = (name: string) => {
  const parts = name.trim().split(" ").filter(Boolean);
  if (parts.length >= 2) {
    return (parts[0][0] + parts[1][0]).toUpperCase();
  }
  return name.substring(0, 2).toUpperCase();
};
---

<Section id="comments" padding="py-16 md:py-24 lg:py-32" background="bg-black">
  <div class="w-full">
    <div
      class="mb-10 lg:mb-12 flex flex-col md:flex-row md:justify-between md:items-end gap-6"
    >
      <div>
        <h2
          class="font-headline text-xs sm:text-sm tracking-[0.3em] md:tracking-[0.4em] text-primary uppercase mb-4 leading-relaxed"
        >
          Comentarios de compañeros de trabajo
        </h2>
        <div class="h-[2px] w-24 bg-maroon-deep"></div>
      </div>

      <div
        class="text-on-surface-variant font-label text-xs sm:text-sm uppercase tracking-widest opacity-40"
      >
        04 / Comentarios
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {
        comments.map((comment) => (
          <div class="group h-full flex flex-col">
            <div class="grow min-h-[250px] bg-surface-container-low p-6 sm:p-8 mb-6 relative overflow-hidden border border-white/10 flex items-center justify-center rounded-lg">
              <div class="absolute inset-0 grid-lines opacity-10" />
              <p class="relative z-10 text-white/80 text-base md:text-xl font-light italic text-center">
                "{comment.comment}"
              </p>
            </div>

            <a
              href={comment.linkedInUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4"
            >
              {comment.photoUrl ? (
                <img
                  src={
                    typeof comment.photoUrl === "string"
                      ? comment.photoUrl
                      : comment.photoUrl.src
                  }
                  alt={comment.fullName}
                  class="w-14 h-14 rounded-full object-cover shrink-0 border border-white/10"
                />
              ) : (
                <div class="w-14 h-14 rounded-full shrink-0 bg-white/10 flex items-center justify-center border border-white/10 text-white font-bold tracking-widest text-lg">
                  {getInitials(comment.fullName)}
                </div>
              )}
              <div>
                <h3 class="font-headline text-lg font-bold mb-1 text-white">
                  {comment.fullName}
                </h3>
                <p class="text-on-surface-variant font-label text-xs uppercase tracking-wider opacity-80">
                  {comment.specialty}
                </p>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</Section>
