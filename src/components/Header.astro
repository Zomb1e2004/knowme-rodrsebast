---
import cvUrl from "../assets/documents/CV_PRINCIPAL.pdf";

export interface Props {
  links: { link: string; href: string }[];
}

const { links = [] } = Astro.props as Props;
---

<header>
  <nav
    class="fixed top-0 w-full z-50 bg-[#36363c]/80 backdrop-blur-md border-b border-white/5 transition-all duration-300 shadow-sm"
  >
    <div class="flex justify-between items-center px-8 py-5 max-w-7xl mx-auto">
      <a
        href="#hero"
        class="text-xl font-bold bg-linear-to-r from-gray-100 to-gray-400 bg-clip-text text-transparent uppercase tracking-widest hover:opacity-80 transition-opacity cursor-pointer"
      >
        R. Sebastian
      </a>

      <div
        class="hidden lg:flex items-center gap-8 text-sm font-medium tracking-wide"
      >
        {
          links.map(({ link, href }) => (
            <a
              href={href}
              class="text-gray-300 hover:text-white hover:-translate-y-0.5 transition-all duration-300"
            >
              {link}
            </a>
          ))
        }

        <a
          href={cvUrl}
          download="Rodrigo - CV.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2 border border-white/10 text-white hover:bg-white/10 hover:border-white/30 transition-all rounded text-xs uppercase tracking-[0.2em] font-bold ml-2 flex items-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            ></path></svg
          >
          CV
        </a>
      </div>

      <!-- Mobile toggle button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-gray-300 hover:text-white focus:outline-none p-2 -mr-2"
        aria-label="Toggle Menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            id="mobile-menu-icon"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div
      id="mobile-menu"
      class="lg:hidden absolute top-full left-0 w-full bg-[#36363c]/95 backdrop-blur-xl border-b border-white/5 shadow-xl flex flex-col px-8 py-6 gap-6 transition-all duration-300 ease-in-out transform opacity-0 invisible -translate-y-4 pointer-events-none"
    >
      {
        links.map(({ link, href }) => (
          <a
            href={href}
            class="text-gray-300 hover:text-white text-base tracking-wide transition-colors mobile-link"
          >
            {link}
          </a>
        ))
      }
      <a
        href={cvUrl}
        download="Rodrigo - CV.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 px-6 py-3 border border-white/10 text-white hover:bg-white/10 transition-all rounded text-sm uppercase tracking-[0.2em] font-bold mt-2 mobile-link"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path></svg
        >
        Descargar CV
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("mobile-menu-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  let isMenuOpen = false;

  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      menu?.classList.remove(
        "opacity-0",
        "invisible",
        "-translate-y-4",
        "pointer-events-none",
      );
      menu?.classList.add(
        "opacity-100",
        "visible",
        "translate-y-0",
        "pointer-events-auto",
      );
      icon?.setAttribute("d", "M6 18L18 6M6 6l12 12");
    } else {
      menu?.classList.add(
        "opacity-0",
        "invisible",
        "-translate-y-4",
        "pointer-events-none",
      );
      menu?.classList.remove(
        "opacity-100",
        "visible",
        "translate-y-0",
        "pointer-events-auto",
      );
      icon?.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
    }
  };

  if (btn && menu && icon) {
    btn.addEventListener("click", toggleMenu);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) toggleMenu();
      });
    });
  }
</script>
