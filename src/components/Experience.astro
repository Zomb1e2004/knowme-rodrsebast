---
import type { ImageMetadata } from "astro";
import Section from "../shared/components/Section.astro";

export interface ExperienceItem {
  companyImage: string | ImageMetadata;
  experienceDescription: string;
  technologiesUsed: string[];
  duration: string;
}

export interface Props {
  experiences: ExperienceItem[];
}

const { experiences } = Astro.props as Props;
---

<Section
  id="experience"
  background="bg-[#550000]"
  border="border-y border-white/5"
  padding="py-16 md:py-24 lg:py-32"
>
  <div class="w-full">
    <div class="mb-10 lg:mb-16">
      <h2
        class="font-headline text-xs sm:text-sm tracking-[0.3em] md:tracking-[0.4em] text-white/70 uppercase mb-4 leading-relaxed"
      >
        02 / Formación académica & Experiencia laboral
      </h2>
      <div class="h-[2px] w-24 bg-white/20"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {
        experiences.map((exp) => (
          <div class="p-8 bg-black/20 rounded-lg backdrop-blur-sm border border-white/10 hover:bg-black/30 transition-all duration-300">
            <div class="flex justify-between items-start mb-6">
              <img
                src={
                  typeof exp.companyImage === "string"
                    ? exp.companyImage
                    : exp.companyImage.src
                }
                alt="Company logo"
                class="w-16 h-16 object-contain rounded-lg"
              />
              {exp.duration && (
                <span class="px-3 py-1.5 border border-white/10 rounded-full text-[10px] md:text-xs font-label text-white/60 tracking-[0.2em] uppercase bg-white/5">
                  {exp.duration}
                </span>
              )}
            </div>

            <p class="font-label text-white/80 text-sm leading-relaxed mb-6">
              {exp.experienceDescription}
            </p>

            <ul class="space-y-1 font-label text-white/80 text-sm">
              {exp.technologiesUsed.map((tech) => (
                <li class="flex items-center gap-3">
                  <span class="w-1.5 h-1.5 bg-white rounded-full" />
                  {tech}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</Section>
